<Configuration status="WARN">
	<Properties>
		<Property name="basePath">./logs</Property>
	</Properties>
	<!--  Appenders section decides where the logs would go(Console/File/Database etc)  -->
	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
		</Console>
		<RollingFile name="File" fileName="${basePath}/automation.log" filePattern="${basePath}/automation-%d{yyyy-MM-dd}-%i.log">
			<PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
			<SizeBasedTriggeringPolicy size="10 MB"/>
		</RollingFile>
	</Appenders>
	<!-- Logger section decides WHAT gets logged and at what level. -->
	<Loggers>
		<Root level="info">
			<!--  Here you can use multiple log levels All < Trace < Debug < Info < Warn < Error < Fatal < Off  -->
			<!-- <AppenderRef ref="Console"/>-->
			<AppenderRef ref="File"/>
		</Root>
	</Loggers>
</Configuration>